  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "~19.1.0",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.3.3"
  },
